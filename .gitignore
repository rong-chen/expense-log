# ----------------------------------------------------------------------
# 项目构建与工具缓存
# ----------------------------------------------------------------------
node_modules/
dist/
dist-ssr/
*.local
.npm/
.yarn/
.pnpm-store/

# ----------------------------------------------------------------------
# Go 编译产物与缓存
# ----------------------------------------------------------------------
bin/
obj/
*.test
*.out
# 后端编译生成的二进制文件
expense-log-server
expense-log
*.exe
server/expense-log-server
server/expense-log
server/main

# ----------------------------------------------------------------------
# 日志文件
# ----------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ----------------------------------------------------------------------
# 应用专属（用户数据与附件）
# ----------------------------------------------------------------------
# 忽略所有的附件数据目录（但保留一个 .gitkeep 占位）
server/attachments/*
!server/attachments/.gitkeep

# 如果有本地数据库文件、或者 sqlite 缓存文件
*.db
*.sqlite
*.sqlite3

# ----------------------------------------------------------------------
# 系统与 IDE 生成文件
# ----------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# ----------------------------------------------------------------------
# 环境变量与机密配置
# ----------------------------------------------------------------------
.env
.env.local
.env.*.local
server/configs/config.yaml
scripts/renew_ssl.sh
